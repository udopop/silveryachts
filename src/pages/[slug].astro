---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

// 1. Get the slug from the URL (e.g., 'contact')
const { slug } = Astro.params;

// 2. Fetch the generic page from Sanity
const pageData = await sanityClient.fetch(
  `*[_type == "page" && slug.current == $slug][0]`,
  { slug }
);

if (!pageData) {
  return Astro.redirect('/404');
}
---

<MainLayout title={pageData.title}>
  <section style="padding: 6rem 2rem; max-width: 1000px; margin: 0 auto; color: #fff;">
    <h1 style="font-family: var(--font-display); font-size: 3.5rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2rem;">
      {pageData.title}
    </h1>
    
    <div style="line-height: 1.8; color: #ccc; font-size: 1.1rem; white-space: pre-line;">
      {pageData.content || "No content added yet."}
    </div>
  </section>
</MainLayout>