---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';

const { slug } = Astro.params;

// Page-Daten aus Sanity abfragen
const pageData = await sanityClient.fetch(
  `*[_type == "page" && slug.current == $slug][0]`,
  { slug }
);

if (!pageData) {
  return Astro.redirect('/404');
}

// Hilfsfunktion für Sanity-Bilder
const builder = imageUrlBuilder(sanityClient);
function urlFor(source) {
  return builder.image(source);
}

// Hero-Bild URL generieren, falls vorhanden
const heroImageUrl = pageData.heroImage ? urlFor(pageData.heroImage).url() : '';
---

<MainLayout title={pageData.title}>
  <header style={`
    position: relative; 
    height: 60vh; 
    min-height: 400px; 
    background: ${heroImageUrl ? `url(${heroImageUrl})` : '#111'}; 
    background-size: cover; 
    background-position: center; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    align-items: center; 
    text-align: center; 
    padding: 2rem;
  `}>
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); z-index: 1;"></div>

    <div style="position: relative; z-index: 2; max-width: 800px; color: #fff;">
      <h1 style="font-family: var(--font-display); font-size: 4rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">
        {pageData.title}
      </h1>
      {pageData.heroSubtitle && (
        <p style="color: var(--gold); font-size: 1.5rem; font-weight: 300; letter-spacing: 0.05em;">
          {pageData.heroSubtitle}
        </p>
      )}
    </div>
  </header>

  <section style="padding: 5rem 2rem; max-width: 800px; margin: 0 auto; color: #fff;">
    <div style="line-height: 1.8; color: #ccc; font-size: 1.2rem; white-space: pre-line; margin-bottom: 4rem;">
      {pageData.content || "No content added yet."}
    </div>

    {pageData.pageImages && pageData.pageImages.length > 0 && (
      <div style="margin-top: 4rem;">
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
          {pageData.pageImages.map((image) => (
            <img 
              src={urlFor(image).url()} 
              alt="Page impression" 
              style="width: 100%; height: 250px; object-fit: cover; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);"
            />
          ))}
        </div>
      </div>
    )}
  </section>
</MainLayout>