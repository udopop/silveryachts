---
import MainLayout from '../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';

// Holt das erste Dokument vom Typ "contact"
const contactData = await sanityClient.fetch(`*[_type == "contact"][0]`);

if (!contactData) {
  // Falls im CMS noch nichts eingetragen wurde, nutzen wir Fallbacks
  var pageTitle = "Contact";
  var email = "info@silveryachts.com";
  var phone = "+61...";
  var person = "Sales Department";
} else {
  var pageTitle = contactData.title;
  var email = contactData.email;
  var phone = contactData.phone;
  var person = contactData.contactPerson;
}
---

<MainLayout title={pageTitle}>
  <section style="padding: 6rem 2rem; max-width: 800px; margin: 0 auto; color: #fff;">
    <h1 style="font-family: var(--font-display); font-size: 3rem; text-transform: uppercase; margin-bottom: 2rem;">
      {pageTitle}
    </h1>
    
    <div style="background: rgba(255,255,255,0.05); padding: 2rem; border-radius: 4px;">
      <h2 style="color: var(--gold); font-size: 1.5rem; margin-bottom: 1.5rem;">{person}</h2>
      <p style="font-size: 1.1rem; margin-bottom: 0.5rem;"><strong>Email:</strong> {email}</p>
      <p style="font-size: 1.1rem;"><strong>Phone:</strong> {phone}</p>
    </div>
  </section>
</MainLayout>