---
import MainLayout from '../../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';

// 1. Get the live slug from the URL parameters (e.g., '24m-silvercat')
const { slug } = Astro.params;

// 2. Fetch the catamaran data from Sanity (stored under the "yacht" document type)
const yacht = await sanityClient.fetch(
  `*[_type == "yacht" && slug.current == $slug][0]`,
  { slug }
);

if (!yacht) {
  return Astro.redirect('/404');
}

// Helper function for Sanity image URLs
const builder = imageUrlBuilder(sanityClient);
function urlFor(source) {
  return builder.image(source);
}
---

<MainLayout title={yacht.name}>
  <section style="padding: 6rem 2rem; max-width: 1000px; margin: 0 auto; color: #fff;">
    <h1 style="font-family: var(--font-display); font-size: 3.5rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">
      {yacht.name}
    </h1>
    <p style="color: var(--gold); font-size: 1.5rem; font-weight: 300; margin-bottom: 3rem;">
      Length: {yacht.laenge}
    </p>

    {yacht.mainImage && (
      <img 
        src={urlFor(yacht.mainImage).url()} 
        alt={yacht.name} 
        style="width: 100%; max-height: 500px; object-fit: cover; margin-bottom: 3rem; border-radius: 4px;"
      />
    )}
    
    <div style="display: grid; grid-template-columns: 1fr; gap: 4rem;">
      <div>
        <h2 style="font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; color: var(--silver);">
          Specification & Design
        </h2>
        <p style="line-height: 1.8; color: #ccc; font-size: 1.1rem; white-space: pre-line; margin-bottom: 4rem;">
          {yacht.beschreibung || "No specification available."}
        </p>
      </div>
    </div>

    {yacht.galerie && yacht.galerie.length > 0 && (
      <div>
        <h2 style="font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem; color: var(--silver);">
          Gallery
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
          {yacht.galerie.map((image) => (
            <img 
              src={urlFor(image).url()} 
              alt={`Impression of ${yacht.name}`} 
              style="width: 100%; height: 220px; object-fit: cover; border-radius: 4px; border: 1px solid rgba(169, 182, 193, 0.2);"
            />
          ))}
        </div>
      </div>
    )}
  </section>
</MainLayout>