---
import MainLayout from '../../layouts/MainLayout.astro';
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';

const { slug } = Astro.params;

const yacht = await sanityClient.fetch(
  `*[_type == "yacht" && slug.current == $slug][0]`,
  { slug }
);

if (!yacht) {
  return Astro.redirect('/404');
}

const builder = imageUrlBuilder(sanityClient);
function urlFor(source) {
  return builder.image(source);
}

const heroImageUrl = yacht.mainImage ? urlFor(yacht.mainImage).url() : '';

const headerStyle = `
  position: relative; 
  height: 60vh; 
  min-height: 400px; 
  background: ${heroImageUrl ? `url(${heroImageUrl})` : '#111'}; 
  background-size: cover; 
  background-position: center; 
  display: flex; 
  flex-direction: column; 
  justify-content: center; 
  align-items: center; 
  text-align: center; 
  padding: 2rem;
`;
---

<MainLayout title={yacht.name}>
  <header style={headerStyle}>
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); z-index: 1;"></div>

    <div style="position: relative; z-index: 2; max-width: 800px; color: #fff;">
      <h1 style="font-family: var(--font-display); font-size: 4rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">
        {yacht.name}
      </h1>
      {yacht.laenge && (
        <p style="color: var(--gold); font-size: 1.5rem; font-weight: 300; letter-spacing: 0.05em;">
          Length: {yacht.laenge}
        </p>
      )}
    </div>
  </header>

  <section style="padding: 5rem 2rem; max-width: 1000px; margin: 0 auto; color: #fff;">
    <div style="display: grid; grid-template-columns: 1fr; gap: 4rem;">
      <div>
        <h2 style="font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; color: var(--silver);">
          Specification & Design
        </h2>
        <p style="line-height: 1.8; color: #ccc; font-size: 1.2rem; white-space: pre-line; margin-bottom: 4rem;">
          {yacht.beschreibung || "No specification available."}
        </p>
      </div>
    </div>

    {yacht.galerie && yacht.galerie.length > 0 && (
      <div style="margin-top: 4rem;">
        <h2 style="font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem; color: var(--silver);">
          Gallery
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
          {yacht.galerie.map((image) => (
            <img 
              src={urlFor(image).url()} 
              alt={`Impression of ${yacht.name}`} 
              style="width: 100%; height: 250px; object-fit: cover; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);"
            />
          ))}
        </div>
      </div>
    )}
  </section>
</MainLayout>